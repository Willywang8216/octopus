octopus-export-*.json
channels.json
groups.json
urls.txt

octllmenv
.env*

# SQLite / embedded DB artifacts (in case a DB is created elsewhere)
*.db
*.sqlite
*.sqlite3
*.db-*
*.sqlite-*
*.wal
*.shm

# Logs / temp
*.log
logs/
tmp/

# Build outputs
build/
static/out/*
!static/out/README.md

# IDE / OS
.vscode/
